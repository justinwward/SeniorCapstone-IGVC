#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
from std_msgs.msg import Bool, Float32
import lgpio
import time


class MotorNode(Node):
    # All of this was mostly copied from Jose's code with a few exceptions like the soft and hard turn parameters
    def __init__(self):
        super().__init__('motor_node')

        # ---------------- GPIO CHIP ----------------
        self.gpio = lgpio.gpiochip_open(4)

        # ---------------- PWM PINS ----------------
        # M1_PWM = one motor
        # M2_PWM = the other motor
        self.M1_PWM = 18
        self.M2_PWM = 19

        lgpio.gpio_claim_output(self.gpio, self.M1_PWM)
        lgpio.gpio_claim_output(self.gpio, self.M2_PWM)

        # ---------------- PWM SETTINGS ----------------
        self.frequency = 1000
        self.stop_duty = 75

        # Forward values for the motors
        self.forward_motor1 = 88
        self.forward_motor2 = 89

        # Reverse values for the motors
        self.reverse_motor1 = 62
        self.reverse_motor2 = 61

        # ---------------- TURN SETTINGS ----------------
        # Soft turns have lower values so the robot will turn slower
        # Hard turns have higher values (and one wheel turns clockwise while the other turns counterclockwise) so the robot turns faster
        self.soft_left_motor1 = 86
        self.soft_left_motor2 = 64

        self.hard_left_motor1 = self.forward_motor1
        self.hard_left_motor2 = self.reverse_motor2

        self.soft_right_motor1 = 66
        self.soft_right_motor2 = 87

        self.hard_right_motor1 = self.reverse_motor1
        self.hard_right_motor2 = self.forward_motor2

        # ---------------- CMD MATCHING ----------------
        self.forward_cmd = 0.12
        self.soft_turn_cmd = 0.30
        self.hard_turn_cmd = 0.60

        self.cmd_tolerance = 0.05
        self.last_state = "STOP"

        # ---------------- LIMELIGHT SETTINGS ----------------
        # Stop sign behavior
        self.stop_sign_area_threshold = 10.0   # tune this after testing
        self.stop_wait_seconds = 3.0
        self.stop_cooldown_seconds = 4.0

        # Lane following thresholds
        self.lane_soft_threshold = 2.0         # tune this
        self.lane_hard_threshold = 6.0         # tune this

        # Pothole avoidance threshold
        self.pothole_center_threshold = 2.0    # degrees; tune this

        # If Limelight messages stop arriving, fall back to LiDAR /cmd_vel
        self.limelight_timeout_sec = 0.75

        # ---------------- LIMELIGHT STATE ----------------
        self.stop_sign_detected = False
        self.stop_sign_ta = 0.0

        # Keeping cone topic names for pothole for now
        self.cone_detected = False
        self.cone_tx = 0.0
        self.cone_ta = 0.0

        self.lane_visible = False
        self.lane_error = 0.0

        self.last_limelight_time = 0.0

        # Stop sign state machine
        self.stop_wait_active = False
        self.stop_wait_until = 0.0
        self.stop_cooldown_until = 0.0

        self.stop_motors()

        # ---------------- ROS SUBSCRIBERS ----------------
        self.create_subscription(
            Twist,
            '/cmd_vel',
            self.cmd_callback,
            10
        )

        # Limelight stop sign topics
        self.create_subscription(
            Bool,
            '/limelight/stop_sign_detected',
            self.stop_sign_callback,
            10
        )
        self.create_subscription(
            Float32,
            '/limelight/stop_sign_ta',
            self.stop_sign_ta_callback,
            10
        )

        # Limelight pothole topics (still using "cone" names for now)
        self.create_subscription(
            Bool,
            '/limelight/cone_detected',
            self.cone_detected_callback,
            10
        )
        self.create_subscription(
            Float32,
            '/limelight/cone_tx',
            self.cone_tx_callback,
            10
        )
        self.create_subscription(
            Float32,
            '/limelight/cone_ta',
            self.cone_ta_callback,
            10
        )

        # Limelight lane topics
        self.create_subscription(
            Bool,
            '/limelight/lane_visible',
            self.lane_visible_callback,
            10
        )
        self.create_subscription(
            Float32,
            '/limelight/lane_error',
            self.lane_error_callback,
            10
        )

        self.get_logger().info('Motor node started. Listening to /cmd_vel and Limelight topics')

    # ---------------- HELPERS ----------------
    # Functions we call depending on what we want the robot to do
    def set_motor_pwm(self, m1_duty, m2_duty):
        lgpio.tx_pwm(self.gpio, self.M1_PWM, self.frequency, m1_duty)
        lgpio.tx_pwm(self.gpio, self.M2_PWM, self.frequency, m2_duty)

    def stop_motors(self):
        self.set_motor_pwm(self.stop_duty, self.stop_duty)

    def drive_forward(self):
        self.set_motor_pwm(self.forward_motor1, self.forward_motor2)

    def soft_left_turn(self):
        self.set_motor_pwm(self.soft_left_motor1, self.soft_left_motor2)

    def hard_left_turn(self):
        self.set_motor_pwm(self.hard_left_motor1, self.hard_left_motor2)

    def soft_right_turn(self):
        self.set_motor_pwm(self.soft_right_motor1, self.soft_right_motor2)

    def hard_right_turn(self):
        self.set_motor_pwm(self.hard_right_motor1, self.hard_right_motor2)

    def log_state_once(self, state):
        if state != self.last_state:
            self.get_logger().info(state)
            self.last_state = state

    def approx_equal(self, value, target):
        return abs(value - target) <= self.cmd_tolerance

    def limelight_is_fresh(self):
        return (time.time() - self.last_limelight_time) <= self.limelight_timeout_sec

    # ---------------- LIMELIGHT CALLBACKS ----------------
    def stop_sign_callback(self, msg):
        self.stop_sign_detected = msg.data
        self.last_limelight_time = time.time()

    def stop_sign_ta_callback(self, msg):
        self.stop_sign_ta = msg.data
        self.last_limelight_time = time.time()

    def cone_detected_callback(self, msg):
        self.cone_detected = msg.data
        self.last_limelight_time = time.time()

    def cone_tx_callback(self, msg):
        self.cone_tx = msg.data
        self.last_limelight_time = time.time()

    def cone_ta_callback(self, msg):
        self.cone_ta = msg.data
        self.last_limelight_time = time.time()

    def lane_visible_callback(self, msg):
        self.lane_visible = msg.data
        self.last_limelight_time = time.time()

    def lane_error_callback(self, msg):
        self.lane_error = msg.data
        self.last_limelight_time = time.time()

    # ---------------- LIMELIGHT DECISION LAYER ----------------
    def apply_limelight_logic(self):
        """
        Returns True if Limelight handled motion decision.
        Returns False if we should fall back to /cmd_vel behavior.
        """
        now = time.time()

        if not self.limelight_is_fresh():
            return False

        # ----- stop sign wait state -----
        if self.stop_wait_active:
            if now < self.stop_wait_until:
                self.stop_motors()
                self.log_state_once('STOP (waiting at stop sign)')
                return True
            else:
                self.stop_wait_active = False
                self.stop_cooldown_until = now + self.stop_cooldown_seconds

        # ----- stop sign trigger -----
        # Cooldown prevents instantly re-triggering on the same stop sign
        if now >= self.stop_cooldown_until:
            if self.stop_sign_detected and self.stop_sign_ta >= self.stop_sign_area_threshold:
                self.stop_wait_active = True
                self.stop_wait_until = now + self.stop_wait_seconds
                self.stop_motors()
                self.log_state_once(
                    f'STOP (stop sign detected close, ta={self.stop_sign_ta:.2f})'
                )
                return True

        # ----- pothole avoidance -----
        # Using current cone topics for potholes
        if self.cone_detected:
            # pothole is left of center -> move right
            if self.cone_tx < -self.pothole_center_threshold:
                self.soft_right_turn()
                self.log_state_once(
                    f'SOFT RIGHT (avoiding pothole, tx={self.cone_tx:.2f})'
                )
                return True

            # pothole is right of center -> move left
            if self.cone_tx > self.pothole_center_threshold:
                self.soft_left_turn()
                self.log_state_once(
                    f'SOFT LEFT (avoiding pothole, tx={self.cone_tx:.2f})'
                )
                return True

            # pothole centered -> default left
            self.soft_left_turn()
            self.log_state_once(
                f'SOFT LEFT (avoiding centered pothole, tx={self.cone_tx:.2f})'
            )
            return True

        # ----- lane following on right side -----
        if self.lane_visible:
            err = self.lane_error

            if abs(err) < self.lane_soft_threshold:
                self.drive_forward()
                self.log_state_once(f'FORWARD (lane follow, err={err:.2f})')
                return True

            if err <= -self.lane_hard_threshold:
                self.hard_left_turn()
                self.log_state_once(f'HARD LEFT (lane follow, err={err:.2f})')
                return True

            if err < -self.lane_soft_threshold:
                self.soft_left_turn()
                self.log_state_once(f'SOFT LEFT (lane follow, err={err:.2f})')
                return True

            if err >= self.lane_hard_threshold:
                self.hard_right_turn()
                self.log_state_once(f'HARD RIGHT (lane follow, err={err:.2f})')
                return True

            if err > self.lane_soft_threshold:
                self.soft_right_turn()
                self.log_state_once(f'SOFT RIGHT (lane follow, err={err:.2f})')
                return True

        # If Limelight is fresh but lane is not visible, stop for safety
        self.stop_motors()
        self.log_state_once('STOP (lane not visible)')
        return True

    # ---------------- CMD CALLBACK ----------------
    # Here we get the command from the /cmd_vel topic and then call the helper functions depending on the linear_x and angular_z values
    def cmd_callback(self, msg):
        # Let Limelight decide first if it has fresh data
        if self.apply_limelight_logic():
            return

        linear_x = msg.linear.x
        angular_z = msg.angular.z

        # Call stop the motors if both are equal to 0
        if self.approx_equal(linear_x, 0.0) and self.approx_equal(angular_z, 0.0):
            self.stop_motors()
            self.log_state_once('STOP')
            return

        # Call drive forward if linear is close to forward_cmd and angular is zero
        if self.approx_equal(linear_x, self.forward_cmd) and self.approx_equal(angular_z, 0.0):
            self.drive_forward()
            self.log_state_once('FORWARD')
            return

        # Call soft left if the linear is close to zero and the angular is close to soft_turn_cmd
        if self.approx_equal(linear_x, 0.0) and self.approx_equal(angular_z, self.soft_turn_cmd):
            self.soft_left_turn()
            self.log_state_once('SOFT LEFT')
            return

        # Call hard left if the linear is close to zero and the angular is close to hard_turn_cmd
        if self.approx_equal(linear_x, 0.0) and self.approx_equal(angular_z, self.hard_turn_cmd):
            self.hard_left_turn()
            self.log_state_once('HARD LEFT')
            return

        # Call soft right if the linear is close to zero and the angular is close to -soft_turn_cmd
        if self.approx_equal(linear_x, 0.0) and self.approx_equal(angular_z, -self.soft_turn_cmd):
            self.soft_right_turn()
            self.log_state_once('SOFT RIGHT')
            return

        # Call hard right if the linear is close to zero and the angular is close to -hard_turn_cmd
        if self.approx_equal(linear_x, 0.0) and self.approx_equal(angular_z, -self.hard_turn_cmd):
            self.hard_right_turn()
            self.log_state_once('HARD RIGHT')
            return

        self.stop_motors()
        self.log_state_once(
            f'STOP (unexpected cmd_vel: lin={linear_x:.2f}, ang={angular_z:.2f})'
        )

    # ---------------- CLEANUP ----------------
    # All of this below was copied from Joses' code
    def destroy_node(self):
        self.stop_motors()
        lgpio.gpiochip_close(self.gpio)
        super().destroy_node()


def main(args=None):
    rclpy.init(args=args)
    node = MotorNode()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
